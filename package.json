{
  "name": "sira-sistema-de-reserva-salas-e-equipamentos",
  "version": "1.0.0",
  "description": "SIRA — Sistema de Reserva de Salas e Equipamentos (Projeto PWEB2)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "pre-commit": "npm run lint && npm run format",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Gabriel Marques",
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "vite": "^8.0.10"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,html,json}": [
      "prettier --write"
    ],
    "*.{js,json,md,yml}": [
      "prettier --write"
    ]
  }
}
