# Dependências
node_modules/

# Produção (Vite)
dist/
dist-ssr/
.vite/
*.local

# Variáveis de ambiente (Vite carrega .env* automaticamente)
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache de ferramentas
.eslintcache
coverage/
.nyc_output/

# Sistema e IDE
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Husky (diretório interno gerado pelo `husky install`)
.husky/_

# Scripts auxiliares locais e artefatos gerados
# O SIRA é front-end JS puro. A pasta .py/ guarda utilitários Python
# (build de PDFs, importadores do board do GitHub) que rodam só local.
# A pasta membros/ guarda PDFs distribuídos para a equipe.
.py
*.pdf
!docs/team-tasks/sprint-1/*.pdf
!docs/reports/sprint-1/*.pdf
*.patch

# Python (caso alguém rode os scripts auxiliares)
*.pyc
__pycache__/
.venv/
venv/
